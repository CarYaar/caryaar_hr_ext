{
  "_comment": "One project entry per Frappe app. The app's PushNotification() class uses its own app name as project_name, so the relay needs a matching entry or send fails with 'Project X not found'. All entries can share the same VAPID + firebase_config.",
  "projects": {
    "frappe": {
      "vapid_public_key": "<VAPID_PUBLIC_KEY>",
      "firebase_config": {
        "apiKey": "<FIREBASE_API_KEY>",
        "authDomain": "<PROJECT_ID>.firebaseapp.com",
        "projectId": "<PROJECT_ID>",
        "storageBucket": "<PROJECT_ID>.firebasestorage.app",
        "messagingSenderId": "<MESSAGING_SENDER_ID>",
        "appId": "<FIREBASE_APP_ID>"
      }
    },
    "gameplan": {
      "vapid_public_key": "<VAPID_PUBLIC_KEY>",
      "firebase_config": {
        "apiKey": "<FIREBASE_API_KEY>",
        "authDomain": "<PROJECT_ID>.firebaseapp.com",
        "projectId": "<PROJECT_ID>",
        "storageBucket": "<PROJECT_ID>.firebasestorage.app",
        "messagingSenderId": "<MESSAGING_SENDER_ID>",
        "appId": "<FIREBASE_APP_ID>"
      }
    },
    "hrms": {
      "vapid_public_key": "<VAPID_PUBLIC_KEY>",
      "firebase_config": {
        "apiKey": "<FIREBASE_API_KEY>",
